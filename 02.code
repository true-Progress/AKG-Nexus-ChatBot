<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>AKGEC Smart Assistant — Glass UI</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <style>
    /* -------------------- Variables & base -------------------- */
    :root{
      --bg: linear-gradient(180deg,#eef6ff,#f8fbff);
      --glass: rgba(255,255,255,0.65);
      --glass-strong: rgba(255,255,255,0.85);
      --primary: #0f6cff;
      --accent: #06b6d4;
      --muted: #6b7280;
      --card-radius: 14px;
      --glass-blur: 12px;
      --text: #0f1724;
    }

    /* Dark theme variables */
    :root.dark{
      --bg: linear-gradient(180deg,#081026,#071423);
      --glass: rgba(20,24,32,0.45);
      --glass-strong: rgba(20,24,32,0.6);
      --primary: #5fb0ff;
      --accent: #38d7e6;
      --muted: #98a0ab;
      --text: #e6eef8;
    }

    html,body{ height:100%; margin:0; padding:0; font-family:Inter,ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,"Helvetica Neue",Arial; background:var(--bg); color:var(--text); -webkit-font-smoothing:antialiased; -moz-osx-font-smoothing:grayscale; }

    .page {
      min-height:100vh;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:28px;
      box-sizing:border-box;
    }

    /* -------------------- Glass card -------------------- */
    .card {
      width: 100%;
      max-width:1100px;
      border-radius: var(--card-radius);
      background: linear-gradient(180deg, rgba(255,255,255,0.55), rgba(255,255,255,0.28));
      backdrop-filter: blur(var(--glass-blur));
      box-shadow: 0 12px 40px rgba(2,6,23,0.12);
      overflow:hidden;
      display:grid;
      grid-template-columns: 420px 1fr;
      gap:18px;
      padding:18px;
      box-sizing:border-box;
    }

    :root.dark .card{
      background: linear-gradient(180deg, rgba(24,28,36,0.5), rgba(12,16,22,0.4));
      box-shadow: 0 12px 40px rgba(0,0,0,0.7);
    }

    /* -------------------- Header inside card -------------------- */
    .card-header {
      grid-column: 1 / -1;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      padding:6px 4px 12px 4px;
    }

    .brand {
      display:flex;
      gap:12px;
      align-items:center;
    }
    .logo {
      width:48px;
      height:48px;
      border-radius:10px;
      background: linear-gradient(135deg,var(--primary),var(--accent));
      display:flex; align-items:center; justify-content:center;
      color:white; font-weight:700; font-size:18px;
      box-shadow: 0 8px 24px rgba(15,99,255,0.12);
    }
    .brand-title { font-size:18px; font-weight:700; }
    .brand-sub { font-size:12px; color:var(--muted); margin-top:2px; }

    .controls { display:flex; gap:8px; align-items:center; }

    .btn {
      background:transparent; border:0; padding:8px 10px; border-radius:10px; cursor:pointer; color:var(--text);
      display:inline-flex; align-items:center; gap:8px; font-weight:600; font-size:13px;
    }
    .btn.primary {
      background: linear-gradient(90deg,var(--primary),var(--accent));
      color:white;
      box-shadow: 0 8px 18px rgba(15,99,255,0.12);
    }

    .theme-toggle {
      width:44px; height:36px; border-radius:8px; display:inline-flex; align-items:center; justify-content:center;
      background: linear-gradient(180deg, rgba(255,255,255,0.6), rgba(255,255,255,0.3));
      border:1px solid rgba(255,255,255,0.35);
    }
    :root.dark .theme-toggle { background: rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.04); }

    /* -------------------- Left: Chat panel -------------------- */
    .chat {
      background: linear-gradient(180deg, rgba(255,255,255,0.55), rgba(255,255,255,0.35));
      border-radius: 12px;
      padding:12px;
      display:flex;
      flex-direction:column;
      min-height:540px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.6);
    }
    :root.dark .chat { background: linear-gradient(180deg, rgba(20,24,32,0.5), rgba(12,16,22,0.35)); }

    .chat-head { display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:8px; }
    .chat-title { font-weight:700; }
    .chat-sub { font-size:12px; color:var(--muted); }

    .quick { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:10px; }
    .chip { background:rgba(255,255,255,0.85); border-radius:999px; padding:8px 12px; font-weight:600; color:var(--primary); cursor:pointer; border:1px solid rgba(0,0,0,0.04); }
    :root.dark .chip { background: rgba(255,255,255,0.02); color:var(--primary); border:1px solid rgba(255,255,255,0.03); }

    .messages {
      flex:1;
      overflow:auto;
      padding:8px;
      border-radius:10px;
      background: linear-gradient(180deg, rgba(255,255,255,0.48), rgba(255,255,255,0.24));
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.35);
    }
    :root.dark .messages { background: linear-gradient(180deg, rgba(20,24,32,0.36), rgba(8,10,14,0.24)); }

    .msg { margin:10px 8px; max-width:78%; padding:12px 14px; border-radius:12px; display:inline-block; word-break:break-word; line-height:1.35; }
    .msg.user { margin-left:auto; background: linear-gradient(180deg, rgba(15,99,255,0.12), rgba(6,182,212,0.06)); color: var(--text); }
    :root.dark .msg.user { background: linear-gradient(180deg, rgba(95,176,255,0.12), rgba(56,215,230,0.06)); }
    .msg.bot { margin-right:auto; background: rgba(255,255,255,0.85); color:var(--text); }
    :root.dark .msg.bot { background: rgba(255,255,255,0.03); color:var(--text); border:1px solid rgba(255,255,255,0.03); }

    .input-area { display:flex; gap:8px; margin-top:12px; align-items:center; }
    .input { flex:1; padding:12px; border-radius:10px; border:1px solid rgba(0,0,0,0.06); background:transparent; outline:none; color:var(--text); font-size:14px; }
    :root.dark .input { border:1px solid rgba(255,255,255,0.04); }

    .send { padding:10px 14px; border-radius:10px; border:0; background:linear-gradient(90deg,var(--primary),var(--accent)); color:white; cursor:pointer; font-weight:700; }

    /* -------------------- Right: Map / Info panel -------------------- */
    .map-panel {
      border-radius:12px;
      background: linear-gradient(180deg, rgba(255,255,255,0.55), rgba(255,255,255,0.3));
      padding:12px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.6);
      min-height:540px;
      display:flex;
      flex-direction:column;
    }
    :root.dark .map-panel { background: linear-gradient(180deg, rgba(20,24,32,0.5), rgba(12,16,22,0.32)); }

    .map-top { display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; }
    .map-wrap { border-radius:10px; overflow:hidden; flex:1; border:1px solid rgba(0,0,0,0.04); background:#fff; }
    :root.dark .map-wrap { border:1px solid rgba(255,255,255,0.03); background:linear-gradient(180deg, rgba(6,8,12,0.6), rgba(2,4,6,0.6)); }

    /* iframe map */
    .map-iframe { width:100%; height:100%; display:block; border:0; }

    .info-list { margin-top:12px; display:flex; gap:8px; flex-wrap:wrap; }
    .info-card { background:rgba(255,255,255,0.9); padding:10px 12px; border-radius:10px; min-width:150px; border:1px solid rgba(0,0,0,0.04); }
    :root.dark .info-card { background: rgba(255,255,255,0.02); border:1px solid rgba(255,255,255,0.03); }

    /* small screen */
    @media (max-width:980px){
      .card { grid-template-columns: 1fr; padding:12px; gap:12px; }
      .map-wrap { height: 360px; }
      .messages { height:360px; }
    }
  </style>
</head>
<body>
  <div class="page">
    <div class="card" id="page-card">
      <div class="card-header">
        <div class="brand">
          <div class="logo">AK</div>
          <div>
            <div class="brand-title">AKG Nexus — SmartBot</div>
            <div class="brand-sub">Campus helpdesk • map • notices • Q&A</div>
          </div>
        </div>

        <div class="controls">
          <button class="btn" id="themeBtn" title="Toggle dark mode">
            <svg id="sun" width="18" height="18" viewBox="0 0 24 24" fill="none" style="display:inline-block"><path d="M12 4V2M12 22v-2M4.93 4.93L3.51 3.51M20.49 20.49l-1.42-1.42M4 12H2M22 12h-2M4.93 19.07l-1.42 1.42M20.49 3.51l-1.42 1.42" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button class="btn primary" id="helpBtn">Help</button>
        </div>
      </div>

      <!-- CHAT (left column) -->
      <div class="chat" aria-live="polite">
        <div class="chat-head">
          <div>
            <div class="chat-title">Ask AKG Nexuso</div>
            <div class="chat-sub">Type questions like "Where is the canteen?", "Show notices", "Fees"</div>
          </div>
        </div>

        <div class="quick" id="quickActions">
          <div class="chip" data-q="Show latest notices">Latest notices</div>
          <div class="chip" data-q="Show news">News</div>
          <div class="chip" data-q="Where is the canteen?">Where is canteen?</div>
          <div class="chip" data-q="Show staff contacts">Staff contacts</div>
          <div class="chip" data-q="Show campus map">Open map</div>
        </div>

        <div class="messages" id="messagesArea"></div>

        <div class="input-area">
          <input id="userInput" class="input" placeholder="Ask anything about AKGEC (e.g., 'placements', 'library hours')" autocomplete="off" />
          <button id="sendBtn" class="send">Send</button>
        </div>
      </div>

      <!-- MAP & INFO (right column) -->
      <div class="map-panel">
        <div class="map-top">
          <div style="font-weight:700">Live Google Campus Map</div>
          <div style="font-size:13px;color:var(--muted)">Zoom & pan to explore</div>
        </div>

        <div class="map-wrap" id="mapWrap">
          <!-- Google Maps Embed (Option A: Embed iframe) -->
          <iframe
            id="liveMap"
            class="map-iframe"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3499.0468093776114!2d77.49791597489216!3d28.676995482238803!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x390cefe36222c42b%3A0x8894320d06c93810!2sAjay%20Kumar%20Garg%20Engineering%20College!5e0!3m2!1sen!2sin!4v1735302061000!5m2!1sen!2sin">
          </iframe>
        </div>

        <div class="info-list" aria-hidden="false">
          <div class="info-card">
            <div style="font-weight:700">Quick Links</div>
            <div style="font-size:13px;color:var(--muted);margin-top:6px">
              <div><a class="link" href="https://www.akgec.ac.in/notice/" target="_blank">Notices</a></div>
              <div><a class="link" href="https://www.akgec.ac.in/faculty/" target="_blank">Faculty</a></div>
              <div><a class="link" href="https://www.akgec.ac.in/academics/fee-structure/" target="_blank">Fee structure</a></div>
            </div>
          </div>

          <div class="info-card">
            <div style="font-weight:700">Contacts</div>
            <div style="font-size:13px;color:var(--muted);margin-top:6px">
              <div>Principal: principal@akgec.ac.in</div>
              <div>Library: library@akgec.ac.in</div>
              <div>Phone: +91-xxxxxxxxxx</div>
            </div>
          </div>
        </div>
      </div>

    </div> <!-- end card -->
  </div> <!-- end page -->

<script>
/* ========================= THEME (dark/light) ========================= */
(function themeInit(){
  const root = document.documentElement;
  const saved = localStorage.getItem('akgec_theme');
  if (saved === 'dark') root.classList.add('dark');

  const themeBtn = document.getElementById('themeBtn');
  themeBtn.addEventListener('click', ()=>{
    root.classList.toggle('dark');
    localStorage.setItem('akgec_theme', root.classList.contains('dark') ? 'dark' : 'light');
  });
})();


/* ---------- Knowledge base (expandable) ---------- */
const knowledgeBase = [
  { keywords: ["fee","fees","tuition","course fee"], answer: "The fee structure varies by branch and year. Check: https://www.akgec.ac.in/academics/fee-structure/" },
  { keywords: ["timing","college timing","class timing","college hours"], answer: "Normal college hours are 8:30 AM to 4:00 PM. Lab schedules may vary by department." },
  { keywords: ["canteen","Me canteen","food","cafeteria","mess"], answer: "Main canteen is near the Mechanical block. It usually operates 8:30 AM - 6:30 PM." },
  { keywords: ["CSIT canteen","cafe"], answer: "CSIT is in the cSIT building ground floor. It usually operates 8:30 AM - 6:30 PM." },
  { keywords: ["library","books","reading room"], answer: "Central Library is open from 9 AM to 8 PM. Use your college library card to issue books." },
  { keywords: ["hostel","hostels","accommodation"], answer: "AKGEC has separate boys' and girls' hostels with mess and WiFi. Contact hostel office for allocations." },
  { keywords: ["bus","transport","bus route","transportation"], answer: "College buses run from Ghaziabad, Noida, Delhi and nearby areas. Contact the transport office for routes & timings." },
  { keywords: ["department","branches","courses"], answer: "AKGEC has CSE, IT, ECE, EN, ME, Civil, AIML and allied departments." },
  { keywords: ["hod","head of department","faculty contact","faculty"], answer: "Faculty contact list is available at: https://www.akgec.ac.in/faculty/" },
  { keywords: ["placement","placements","tpo","training"], answer: "The placement cell actively engages companies for internships and placements. More: https://www.akgec.ac.in/placements/" },
  { keywords: ["notice","notices","circular"], answer: "You can find notices at: https://www.akgec.ac.in/notice/" },
  { keywords: ["admission","admissions","apply"], answer: "Admission details & schedule are on the official site: https://www.akgec.ac.in/." },
  { keywords: ["map","campus map","location","where is","where's","where"], answer: "__SHOW_MAP__" },
  { keywords: ["events","fest","fests","cultural","technical"], answer: "Upcoming events and announcements are on the Notices / News pages. Check: https://www.akgec.ac.in/notice" },
  { keywords: ["anti-ragging","ragging"], answer: "AKGEC follows strict anti-ragging policies. Report any incidents to admin or the anti-ragging committee." },
  { keywords: ["contact","phone","phone number","telephone"], answer: "General contact info: principal@akgec.ac.in. For specific departments check https://www.akgec.ac.in/." },
  { keywords: ["exam","exams","timetable"], answer: "Exam schedules & timetables are published on the Notices page. Contact respective HOD for clarifications." },
  { keywords: ["clubs","societies","technical clubs","clubs and societies"], answer: "AKGEC hosts multiple clubs: robotics, coding, cultural, sports and more. Check the events/notices for club activities." },
  { keywords: ["scholarship","scholarships","financial aid"], answer: "Scholarship information (if any) will be posted on the official site and notice board." },
  { keywords: ["library timings","library hours"], answer: "Library: 9 AM to 8 PM (subject to change on exams/holidays)." },
  { keywords: ["gym","sports","sports complex"], answer: "Sports complex and gym are available on campus — check sports office for timings and booking." },
  // Add more entries as you like...
];

/* ---------- synonyms dictionary for expansion ---------- */
const synonyms = {
  "fee": ["fees","tuition","charges"],
  "canteen": ["cafeteria","mess","food"],
  "faculty": ["teachers","staff","professor","prof"],
  "hod": ["head of department"],
  "map": ["location","directions","where","where is"],
  "notice": ["circular","announcement","notice"],
  "placement": ["placements","tpo","training"]
};

/* ---------- helper: expand keywords ---------- */
function expandKeywords(word){
  return (synonyms[word] ? [word, ...synonyms[word]] : [word]).map(w => w.toLowerCase());
}

/* ---------- Levenshtein (for fuzzy tolerance) ---------- */
function levenshtein(a, b) {
  if (!a) return b ? b.length : 0;
  if (!b) return a ? a.length : 0;
  a = a.toLowerCase(); b = b.toLowerCase();
  const matrix = Array.from({length: b.length+1}, (_, i) => Array(a.length+1).fill(0));
  for (let i=0;i<=b.length;i++) matrix[i][0] = i;
  for (let j=0;j<=a.length;j++) matrix[0][j] = j;
  for (let i=1;i<=b.length;i++){
    for (let j=1;j<=a.length;j++){
      if (b[i-1] === a[j-1]) matrix[i][j] = matrix[i-1][j-1];
      else matrix[i][j] = Math.min(matrix[i-1][j-1]+1, matrix[i][j-1]+1, matrix[i-1][j]+1);
    }
  }
  return matrix[b.length][a.length];
}

/* ---------- fuzzy matching scoring ---------- */
function fuzzyScore(text, keyword){
  text = text.toLowerCase();
  keyword = keyword.toLowerCase();
  if (text.includes(keyword)) return 1.0;
  if (keyword.includes(text) || text.startsWith(keyword) || text.endsWith(keyword)) return 0.8;
  const dist = levenshtein(text.replace(/\s/g,''), keyword.replace(/\s/g,''));
  if (dist <= 2) return 0.6;
  if (keyword.split(' ').some(k => text.includes(k))) return 0.7;
  return 0;
}

/* ---------- main KB lookup ---------- */
function lookupKnowledge(userText){
  let best = {score:0, answer:null};
  const cleaned = userText.toLowerCase();

  knowledgeBase.forEach(entry=>{
    entry.keywords.forEach(kw=>{
      // expand with synonyms
      const expanded = expandKeywords(kw);
      expanded.forEach(w=>{
        const s = fuzzyScore(cleaned, w);
        if (s > best.score){
          best.score = s;
          best.answer = entry.answer;
        }
      });
    });
  });

  if (best.score >= 0.5) return best.answer;
  return null;
}

/* ========================= Chat UI & handling ========================= */
const messagesArea = document.getElementById('messagesArea');
const sendBtn = document.getElementById('sendBtn');
const userInput = document.getElementById('userInput');
const quickActions = document.getElementById('quickActions');

function appendMessage(text, who='bot'){
  const el = document.createElement('div');
  el.className = 'msg ' + (who === 'user' ? 'user' : 'bot');
  el.innerHTML = (who === 'user' ? '<strong>You:</strong> ' : '<strong>Bot:</strong> ') + text;
  messagesArea.appendChild(el);
  messagesArea.scrollTop = messagesArea.scrollHeight;
}

function botReplyRaw(text){
  appendMessage(text, 'bot');
}

/* initial greeting */
appendMessage('Hi 👋 I am AKGEC Assistant. I can show notices, answer FAQs, and open the campus map. Try: "Show latest notices" or "Where is the canteen?"', 'bot');

/* wire quick chips */
document.querySelectorAll('.chip').forEach(c=>{
  c.addEventListener('click', ()=> { const q = c.getAttribute('data-q'); if(q) handleUserQuery(q); });
});

/* send handlers */
sendBtn.addEventListener('click', ()=> { handleUserQuery(userInput.value); });
userInput.addEventListener('keydown', (e)=> { if(e.key === 'Enter') handleUserQuery(userInput.value); });

/* main query handler */
async function handleUserQuery(text){
  const trimmed = (text || '').trim();
  if (!trimmed) return;
  appendMessage(escapeHtml(trimmed), 'user');
  userInput.value = '';

  // try knowledge base first (fast)
  const kb = lookupKnowledge(trimmed);
  if (kb){
    // handle map token specially
    if (kb === "__SHOW_MAP__"){
      botReplyRaw('Opening live campus map below. Use zoom/pan to explore.');
      // show a small embedded map block in the chat (iframe)
      botReplyRaw(`<div style="margin-top:8px"><iframe width="100%" height="320" style="border:0;border-radius:10px;" loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade" src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3499.0468093776114!2d77.49791597489216!3d28.676995482238803!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x390cefe36222c42b%3A0x8894320d06c93810!2sAjay%20Kumar%20Garg%20Engineering%20College!5e0!3m2!1sen!2sin!4v1735302061000!5m2!1sen!2sin"></iframe></div>`);
      return;
    }
    botReplyRaw(kb);
    return;
  }

  // then try keyword match across KB keywords more flexibly
  const smart = await fallbackSmartAnswer(trimmed);
  if (smart) { botReplyRaw(smart); return; }

  // try fetch notices/news selectively if user asked
  const lower = trimmed.toLowerCase();
  if (lower.includes('notice') || lower.includes('notices')) { fetchNotices(); return; }
  if (lower.includes('news')) { fetchNews(); return; }

  // fallback small talk
  if (/hi|hello|hey/i.test(trimmed)) { botReplyRaw('Hello! How can I help you at AKGEC today?'); return; }

  botReplyRaw("Sorry, I couldn't find an exact answer. Try: 'Show notices', 'Where is the library?', 'Fees', or 'Show campus map'.");
}

/* fallback smart function: attempt to find best KB entry by scoring individual words */
async function fallbackSmartAnswer(text){
  const words = text.toLowerCase().split(/\s+/).filter(Boolean);
  let best = {score:0, answer:null};
  knowledgeBase.forEach(entry=>{
    entry.keywords.forEach(kw=>{
      const expanded = expandKeywords(kw);
      expanded.forEach(eKW=>{
        // score by presence of keyword tokens among words and fuzzy scores
        const s = fuzzyScore(text, eKW);
        if (s > best.score){
          best.score = s;
          best.answer = entry.answer;
        }
      });
    });
  });
  if (best.score >= 0.45) return best.answer;
  return null;
}

/* ========================= Notices & News (best-effort scraping) ========================= */
async function fetchNotices(){
  const url = 'https://www.akgec.ac.in/notice';
  botReplyRaw('Trying to fetch Notices from the official site...');
  try {
    const res = await fetch(url, { mode:'cors' });
    if (!res.ok) throw new Error('Network error ' + res.status);
    const html = await res.text();
    const items = parseNotices(html);
    if (items && items.length){
      botReplyRaw('<b>Latest notices:</b>');
      items.slice(0,6).forEach((it,i)=> {
        botReplyRaw(`${i+1}. ${escapeHtml(it.title)} <br/><a href="${it.link}" target="_blank">${it.link}</a>`);
      });
    } else {
      botReplyRaw('Could not parse notices automatically — opening Notices page: <a href="'+url+'" target="_blank">'+url+'</a>');
    }
  } catch (err) {
    console.warn('fetchNotices failed', err);
    botReplyRaw('Unable to fetch notices directly (CORS or network). Open: <a href="'+url+'" target="_blank">'+url+'</a>');
  }
}

async function fetchNews(){
  const url = 'https://www.akgec.ac.in/news';
  botReplyRaw('Trying to fetch News from the official site...');
  try {
    const res = await fetch(url, { mode:'cors' });
    if (!res.ok) throw new Error('Network error ' + res.status);
    const html = await res.text();
    const items = parseNotices(html);
    if (items && items.length){
      botReplyRaw('<b>Latest news:</b>');
      items.slice(0,6).forEach((it,i)=> {
        botReplyRaw(`${i+1}. ${escapeHtml(it.title)} <br/><a href="${it.link}" target="_blank">${it.link}</a>`);
      });
    } else {
      botReplyRaw('Could not parse news automatically — opening News page: <a href="'+url+'" target="_blank">'+url+'</a>');
    }
  } catch (err) {
    console.warn('fetchNews failed', err);
    botReplyRaw('Unable to fetch news directly (CORS or network). Open: <a href="'+url+'" target="_blank">'+url+'</a>');
  }
}

/* simple HTML parsing heuristic */
function parseNotices(html){
  try {
    const doc = new DOMParser().parseFromString(html, 'text/html');
    const links = Array.from(doc.querySelectorAll('a'));
    const items = [];
    for (const a of links){
      const text = (a.textContent || '').trim();
      const href = a.href || a.getAttribute('href') || '';
      if (!text) continue;
      // heuristics: likely a notice link often has dates or 'notice' or is not site-nav
      if (text.length > 10 && (href.toLowerCase().includes('notice') || text.toLowerCase().includes('notice') || text.match(/[A-Za-z0-9]/))) {
        const link = href.startsWith('http') ? href : ('https://www.akgec.ac.in' + (href.startsWith('/') ? href : '/' + href));
        items.push({ title: text, link });
      }
    }
    // dedupe by title snippet
    const seen = new Set(); const uniq = [];
    for (const it of items){
      const key = it.title.slice(0,80);
      if (!seen.has(key)) { seen.add(key); uniq.push(it); }
      if (uniq.length >= 12) break;
    }
    return uniq;
  } catch(e){ return null; }
}

/* ========================= Staff directory (static) ========================= */
const staffDirectory = [
  { name:'Dr. Raj (HOD CSE)', phone:'+91-1234567890', email:'raj@akgec.ac.in', cabin:'Block A, 101' },
  { name:'Prof. Sharma (Principal)', phone:'+91-9876543210', email:'principal@akgec.ac.in', cabin:'Admin Office' },
  { name:'Mrs. Mehta (Library Incharge)', phone:'+91-7012345678', email:'library@akgec.ac.in', cabin:'Library' },
];

function showStaff(){
  botReplyRaw('<b>Staff contacts (sample):</b>');
  staffDirectory.forEach(s => {
    botReplyRaw(`${s.name}<br/>Phone: ${escapeHtml(s.phone)}<br/>Email: <a href="mailto:${escapeHtml(s.email)}">${escapeHtml(s.email)}</a><br/>Cabin: ${escapeHtml(s.cabin)}`);
  });
}

/* ========================= Utilities ========================= */
function escapeHtml(unsafe){
  return String(unsafe)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;').replace(/'/g,'&#039;');
}

/* expose map via quick action "Open map" */
document.querySelectorAll('.chip').forEach(ch=>{
  ch.addEventListener('click', ()=>{
    const q = ch.getAttribute('data-q') || '';
    if (/map/i.test(q)) {
      // scroll map into view and give feedback
      botReplyRaw('Opening live campus map — use zoom & pan in the right panel.');
      document.getElementById('liveMap').scrollIntoView({behavior:'smooth', block:'center'});
    }
  });
});

/* support Help & sample quick replies */
document.getElementById('helpBtn').addEventListener('click', ()=>{
  botReplyRaw('Try questions like: "Show latest notices", "Where is the canteen?", "Fees", "Library hours", "Show campus map".');
});

/* allow links inside messages to be clickable (delegated) */
messagesArea.addEventListener('click', (e)=>{
  const a = e.target.closest('a');
  if (a) {
    a.target = '_blank';
  }
});

</script>
</body>
</html>
